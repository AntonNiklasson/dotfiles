#!/usr/bin/env bash

set -euo pipefail

LAYOUTS=(
  "claude-vim;claude + vim + terminal"
)

preview_layout() {
  case "$1" in
    claude-vim)
      cat <<'ART'
┌───────────────┬───────────────┐
│               │               │
│    claude     │      vim      │
│     50%       │               │
│               │               │
│               ├───────────────┤
│               │   terminal    │
│               │     20%       │
└───────────────┴───────────────┘
ART
      ;;
  esac
}

apply_claude_vim() {
  local pane_count dir

  # kill panes beyond the 3rd
  pane_count=$(tmux list-panes | wc -l | tr -d ' ')
  while [ "$pane_count" -gt 3 ]; do
    tmux kill-pane -t ":.{last}"
    pane_count=$((pane_count - 1))
  done

  # add panes until we have 3
  dir=$(tmux display-message -p '#{pane_current_path}')
  while [ "$pane_count" -lt 3 ]; do
    tmux split-window -h -c "$dir"
    pane_count=$((pane_count + 1))
  done

  # normalize: main-vertical puts pane 0 left, panes 1/2 stacked on right
  tmux select-layout main-vertical

  # resize: pane 0 = 50% width, pane 2 = 20% height
  tmux resize-pane -t 0 -x 50%
  tmux resize-pane -t 2 -y 20%
  tmux select-pane -t 0
}

if [ "${1:-}" = "--preview" ]; then
  preview_layout "$2"
  exit 0
elif [ -n "${1:-}" ]; then
  name="$1"
else
  name=$(
    printf '%s\n' "${LAYOUTS[@]}" |
      fzf --reverse --no-info --prompt='layout> ' --delimiter=';' --with-nth=2 \
        --preview="$0 --preview {1}" --preview-window=right:35 |
      cut -d';' -f1
  )
fi

case "$name" in
  claude-vim) apply_claude_vim ;;
  *) echo "Unknown layout: $name"; exit 1 ;;
esac
